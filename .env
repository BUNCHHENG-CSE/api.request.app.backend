# Server Configuration
SERVER_PORT=8080
GIN_MODE=release # Use 'debug' for development
JWT_SECRET=your_super_secret_jwt_key_here

# PostgreSQL Database Configuration
DB_HOST=db       # Use 'localhost' if running outside Docker
DB_USER=postgres
DB_PASSWORD=secret
DB_NAME=request_app
DB_PORT=5432
DB_SSLMODE=disable

# Full DSN for GORM
DATABASE_URL=host=${DB_HOST} user=${DB_USER} password=${DB_PASSWORD} dbname=${DB_NAME} port=${DB_PORT} sslmode=${DB_SSLMODE}